<% content_for :title, "MiniCAD — 2D plans, drawn in your browser" %>

<section class="pt-6 pb-12 sm:pt-12">
  <p class="eyebrow mb-3">browser cad · nothing to install</p>
  <h1 class="text-4xl sm:text-5xl font-bold tracking-tighter leading-[1.05] max-w-2xl">
    2D plans, drawn<br>in your browser.
  </h1>
  <p class="mt-5 text-base text-ink-soft max-w-xl leading-relaxed">
    MiniCAD is a small drafting tool for solo architects. The commands you already
    know — <span class="font-mono text-sm">L</span>, <span class="font-mono text-sm">REC</span>,
    <span class="font-mono text-sm">TRIM</span>, <span class="font-mono text-sm">FILLET</span> —
    DXF in and out, and prints that hold their scale.
  </p>
  <div class="mt-7 flex flex-wrap items-center gap-3">
    <%= link_to "Try the editor — no account", try_path, class: "btn-ink" %>
    <%= link_to "Sign in with Google", new_user_session_path, class: "btn-ghost" %>
  </div>
</section>

<%# honest CSS/SVG mock of the actual editor: dark board, drawn plan, command line %>
<section class="tblock !p-0 mb-14" aria-hidden="true">
  <div class="bg-[#131519] relative overflow-hidden">
    <svg viewBox="0 0 960 340" class="w-full block">
      <defs>
        <pattern id="grid" width="24" height="24" patternUnits="userSpaceOnUse">
          <path d="M 24 0 L 0 0 0 24" fill="none" stroke="#1f242c" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="960" height="340" fill="url(#grid)"/>
      <!-- a floor plan corner, as the engine draws it -->
      <g stroke="#d8dbe2" stroke-width="1.5" fill="none">
        <path d="M 240 260 L 240 90 L 560 90 L 560 160"/>
        <path d="M 252 260 L 252 102 L 560 102"/>
        <path d="M 560 200 L 560 260 L 400 260"/>
        <circle cx="480" cy="185" r="34"/>
      </g>
      <!-- door swing -->
      <g stroke="#8b93a1" stroke-width="1" fill="none">
        <path d="M 560 160 A 40 40 0 0 1 600 200"/>
        <line x1="560" y1="160" x2="560" y2="200" stroke-dasharray="3 3"/>
      </g>
      <!-- dimension line -->
      <g stroke="#43d6b5" stroke-width="1" fill="none">
        <line x1="240" y1="66" x2="560" y2="66"/>
        <line x1="240" y1="60" x2="240" y2="84"/>
        <line x1="560" y1="60" x2="560" y2="84"/>
      </g>
      <text x="400" y="58" fill="#43d6b5" font-family="ui-monospace,Menlo,monospace" font-size="12" text-anchor="middle">320.00</text>
      <!-- crosshair -->
      <g stroke="#4db8ff" stroke-width="1">
        <line x1="640" y1="228" x2="680" y2="228"/>
        <line x1="660" y1="208" x2="660" y2="248"/>
        <rect x="655" y="223" width="10" height="10" fill="none"/>
      </g>
    </svg>
    <div class="border-t border-[#2e333d] bg-[#1c1f25] px-4 py-2.5 font-mono text-xs">
      <span class="text-[#f2b950]">Command:</span>
      <span class="text-[#d8dbe2]"> DIM</span>
      <span class="text-[#43d6b5] animate-pulse">▍</span>
    </div>
  </div>
</section>

<div class="dim-line mb-10">what it does</div>

<section class="grid gap-5 sm:grid-cols-3 mb-16">
  <div class="tblock !shadow-none">
    <div class="px-4 py-2.5"><span class="eyebrow !text-teal-deep">01 · draw</span></div>
    <div class="tblock-row px-4 py-4">
      <h2 class="font-bold tracking-tight mb-1.5">Commands you already know</h2>
      <p class="text-sm text-dim leading-relaxed">Type <span class="font-mono text-xs">L</span> for line,
        right-click for Enter, <span class="font-mono text-xs">@3&lt;45</span> for polar.
        Osnap, ortho, grips, undo — the drafting muscle memory works here.</p>
    </div>
  </div>
  <div class="tblock !shadow-none">
    <div class="px-4 py-2.5"><span class="eyebrow !text-teal-deep">02 · exchange</span></div>
    <div class="tblock-row px-4 py-4">
      <h2 class="font-bold tracking-tight mb-1.5">DXF native</h2>
      <p class="text-sm text-dim leading-relaxed">Export R12 DXF that opens in AutoCAD,
        LibreCAD and QCAD. Import is on the bench — opening the file a client
        sent you is the whole point.</p>
    </div>
  </div>
  <div class="tblock !shadow-none">
    <div class="px-4 py-2.5"><span class="eyebrow !text-teal-deep">03 · print</span></div>
    <div class="tblock-row px-4 py-4">
      <h2 class="font-bold tracking-tight mb-1.5">Prints to scale</h2>
      <p class="text-sm text-dim leading-relaxed">1:50 on A4 means 1:50 on paper —
        pick paper, scale and window, run the test page, then print the real sheet.</p>
    </div>
  </div>
</section>

<footer class="dim-line pb-10">minicad · drawn in the browser</footer>
