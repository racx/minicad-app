<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "MiniCAD" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%# Editor is served by Vite only — the engine brings its own CSS.
        No Tailwind, no importmap/Turbo here. %>
    <%= vite_client_tag %>
    <%= vite_javascript_tag "editor" %>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
