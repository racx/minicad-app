<%= turbo_frame_tag @drawing do %>
  <%= form_with model: @drawing, class: "flex items-center gap-2 px-5 py-3" do |f| %>
    <%= f.text_field :title, autofocus: true,
          class: "flex-1 border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-400" %>
    <%= f.submit "Save",
          class: "bg-gray-900 hover:bg-gray-700 text-white text-sm px-3 py-1.5 rounded-lg cursor-pointer" %>
    <%= link_to "Cancel", drawings_path, data: { turbo_frame: "_top" },
          class: "text-sm text-gray-500 hover:text-gray-800 px-2 py-1" %>
  <% end %>
<% end %>
