<% content_for :title, "Drawings — MiniCAD" %>

<div class="flex items-end justify-between mb-8">
  <div>
    <p class="eyebrow mb-1.5">sheet index</p>
    <h1 class="text-2xl font-bold tracking-tight">Your drawings</h1>
  </div>
  <%= button_to "+ New drawing", drawings_path, class: "btn-ink" %>
</div>

<% if @drawings.any? %>
  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    <% @drawings.each do |drawing| %>
      <%= render "drawing", drawing: drawing, sheet_number: @sheet_numbers[drawing.id] %>
    <% end %>
  </div>
<% else %>
  <div class="border-2 border-dashed border-rule bg-sheet/60 px-8 py-16 text-center">
    <p class="eyebrow mb-2">flat file empty</p>
    <p class="text-lg font-bold tracking-tight mb-1">A blank sheet is waiting.</p>
    <p class="text-sm text-dim mb-6">Draw with the same commands as the big desks — L, REC, C — right in the browser.</p>
    <%= button_to "Start sheet A-001", drawings_path, class: "btn-ink" %>
  </div>
<% end %>
