<%= turbo_frame_tag drawing do %>
  <div class="flex items-center justify-between px-5 py-4">
    <div class="min-w-0">
      <%= link_to drawing.title, edit_drawing_path(drawing), data: { turbo_frame: "_top" },
            class: "font-medium text-gray-900 hover:underline truncate block" %>
      <p class="text-xs text-gray-500 mt-0.5">
        <%= drawing.units %> · updated <%= time_ago_in_words(drawing.updated_at) %> ago
      </p>
    </div>
    <div class="flex items-center gap-2 shrink-0 ml-4">
      <%= link_to "Rename", rename_drawing_path(drawing),
            class: "text-sm text-gray-500 hover:text-gray-800 px-2 py-1" %>
      <%= button_to "Delete", drawing_path(drawing), method: :delete,
            form: { data: { turbo_confirm: "Delete “#{drawing.title}”? This cannot be undone." },
                    class: "inline" },
            data: { turbo_frame: "_top" },
            class: "text-sm text-red-500 hover:text-red-700 px-2 py-1 cursor-pointer" %>
    </div>
  </div>
<% end %>
